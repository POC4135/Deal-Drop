NODE_ENV=development
APP_ENV=dev
PORT=3000
LOG_LEVEL=info

DATABASE_URL=postgres://postgres:postgres@localhost:5432/dealdrop
REDIS_URL=redis://localhost:6379

AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=local-dev-pool
COGNITO_CLIENT_ID=local-dev-client
JWT_AUDIENCE=dealdrop
JWT_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/local-dev-pool

EVENT_BUS_NAME=dealdrop-dev
MEDIA_BUCKET=dealdrop-dev-media
PROOF_BUCKET=dealdrop-dev-proofs

# Keep true until the Cognito-backed auth path is enabled.
USE_DEV_AUTH=true
