# Database
# Local: postgres://postgres@localhost:5432/dealdrop_dev
# Production: postgres://user:password@host:5432/dealdrop
DATABASE_URL=postgres://postgres@localhost:5432/dealdrop_dev

# Auth (Phase B — stub for now, real Cognito in Phase E)
# JWT_SECRET is used by the dev stub issuer only
JWT_SECRET=change-me-local-dev-secret

# AWS (Phase E)
# AWS_REGION=us-east-1
# COGNITO_USER_POOL_ID=us-east-1_xxxxx
# COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# App
NODE_ENV=development
PORT=3000
